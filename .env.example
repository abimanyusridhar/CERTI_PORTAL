###
# Synergy Certificate Verification Portal
# Tenant-aware Phase 1 configuration
#
# Copy to `.env` and fill in values (do NOT commit real secrets).
###

# Server
PORT=3000
BASE_ORIGIN=https://your-public-domain.com

# Tenant isolation (SaaS Phase 1)
# - If set: certificates/VAPT records, tracking logs, crypto keys, and uploads are stored under:
#     data/<TENANT_ID>/...
#     uploads/<TENANT_ID>/...
# - If unset: uses legacy paths (data/*.json and uploads/*).
TENANT_ID=customer_a_001

# Admin auth (used for /api/auth/login)
ADMIN_USER=admin
ADMIN_PASS=change-me

# ── AWS Cognito SSO (optional — leave blank to use username/password login) ──
# Step-by-step setup: see docs/SSO_SETUP.md
#
# 1. Create a Cognito User Pool in AWS Console (ap-south-1 or your region)
# 2. In App Clients, create a "Public client" with:
#    - Grant type: Authorization code
#    - Callback URL: https://your-domain.com/auth/sso/callback
#    - Sign-out URL: https://your-domain.com/
#    - Scopes: openid, email, profile
# 3. Set up a hosted UI domain (e.g. myapp.auth.ap-south-1.amazoncognito.com)
# 4. (Optional) Create a Cognito Group named "Admins" — users in this group
#    get admin-level access; all other verified users get superintendent access.
#
COGNITO_REGION=ap-south-1
COGNITO_USER_POOL_ID=ap-south-1_XXXXXXXXX
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
# COGNITO_CLIENT_SECRET=  # only needed if your App Client has a secret
COGNITO_DOMAIN=myapp.auth.ap-south-1.amazoncognito.com
# Name of the Cognito User Pool Group that grants admin access (case-sensitive)
COGNITO_ADMIN_GROUP=Admins
# Name of the Cognito User Pool Group that grants read-only "client" access — same
# real admin dashboards, full data, every mutating action hidden/rejected (case-sensitive)
COGNITO_CLIENT_GROUP=client

# AWS SES (optional: enables credential email dispatch)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# Verified SES "From" identities
# - Must match an identity verified in AWS SES for the configured AWS_REGION.
# - You may use either `sender@example.com` or `Display Name <sender@example.com>` format.
AWS_SES_FROM_CST="Synergy CST <trainingawareness@synergyship.com>"
AWS_SES_FROM_VAPT="Synergy VAPT <vapt@synergyship.com>"

# S3 storage hardening (optional)
# Set S3_SSE=AES256 for S3-managed encryption, or S3_SSE=aws:kms with S3_KMS_KEY_ID.
# S3_SSE=AES256
# S3_KMS_KEY_ID=arn:aws:kms:ap-south-1:123456789012:key/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── CSRF / CSP hardening rollout flags (Phase 1 security remediation) ──
# Both default to "false" (log-only / report-only) so each protection can bake in
# against real traffic before it starts blocking or enforcing anything. Flip to
# "true" only after confirming the corresponding logs/reports are clean.
#
# CSRF_ENFORCE=false (default): double-submit CSRF check computes pass/fail and
# logs mismatches, but never blocks. CSRF_ENFORCE=true: mismatches get a 403.
# CSRF_ENFORCE=false
#
# CSP_ENFORCE_NO_INLINE=false (default): the strict CSP (no script-src
# 'unsafe-inline') is sent only as Content-Security-Policy-Report-Only, so
# violations are logged via POST /api/csp-report without breaking anything —
# the enforcing header keeps 'unsafe-inline'. CSP_ENFORCE_NO_INLINE=true: the
# strict policy becomes the real enforcing header (hard cutover).
# CSP_ENFORCE_NO_INLINE=false

# ── DynamoDB (Phase 1 storage migration — see terraform/, scripts/migrate-to-dynamo.js) ──
# Table/GSI are provisioned by `terraform apply` in terraform/. This app never
# creates the table itself. Leave DYNAMO_TABLE_NAME unset to keep using
# JSON/S3 storage exactly as today (no behavior change).
# DYNAMO_TABLE_NAME=synergy-cert-portal
# DYNAMO_REGION=ap-south-1
# Falls back to S3_ACCESS_KEY/S3_SECRET_KEY, then AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY,
# if not set — only set these separately if the app's DynamoDB IAM identity
# differs from its S3 identity.
# DYNAMO_ACCESS_KEY=
# DYNAMO_SECRET_KEY=
#
# Rollout flags — both default "false" (no DynamoDB traffic at all, identical
# to today's behavior). See docs/data-structure-migration-plan.md for the
# full dual-write → shadow-read → cutover sequence; do not enable both
# out of order. Certificates (CST *and* VAPT), Documents, Users, and Groups
# are the only collections wired up — email logs, tracking events, and legacy
# doc-access-requests intentionally stay JSON/S3-only.
#
# DUAL_WRITE_DYNAMO=false  # true: every save() also writes to DynamoDB; reads stay on JSON/S3
# SHADOW_READ_DYNAMO=false # true: background-diffs DynamoDB against JSON/S3 on every load(), logs mismatches, never served
