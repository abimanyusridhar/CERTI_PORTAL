
# --- Environment files ---
.env
.env.*
!.env.example

# --- IDE / Editor settings ---
.idea/
.vscode/
*.swp
*.swo

# --- OS files ---
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# --- Logs / Temp / Caches ---
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
*.tmp
*.temp
tmp/
temp/
.cache/
.nyc_output/

# --- Build & Dependencies ---
node_modules/
dist/
build/
coverage/
.next/
out/
.parcel-cache/

# --- Application Data (Production Security) ---
# Runtime-generated JSON/JSONL — never commit; server creates these on first run
data/*.json
data/*.jsonl
data/.keys.json

# Tenant-scoped data directories (runtime; includes integration test tenants)
# Ignoring the directory covers all files within it, no need for nested globs
data/*/

# --- User Uploads ---
# All uploaded content is runtime — never commit
# Only the root placeholder (uploads/.gitkeep) is tracked to preserve the directory
uploads/**
!uploads/.gitkeep

# --- Scripts & Tools ---
# Ignore temporary outputs from scripts
scripts/output/

# --- Playwright E2E ---
test-results/
playwright-report/
blob-report/

# --- Documentation ---
*.md
!README.md
!docs/
!docs/**/*.md
