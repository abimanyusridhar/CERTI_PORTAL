
# --- Environment files ---
.env
.env.*
!.env.example

# --- IDE / Editor settings ---
.idea/
.vscode/
*.swp
*.swo

# --- OS files ---
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# --- Logs / Temp / Caches ---
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
*.tmp
*.temp
tmp/
temp/
.cache/
.nyc_output/

# --- Build & Dependencies ---
node_modules/
dist/
build/
coverage/
.next/
out/
.parcel-cache/

# --- Application Data (Production Security) ---
# Ignore all sensitive data files that are generated or modified at runtime
data/*.json
data/*.jsonl
data/**/*.json
data/**/*.jsonl
data/.keys.json

# Allow specific data structure files if they exist and are non-sensitive
# !data/schema.json

# --- User Uploads ---
# Ignore all uploaded files in production
uploads/**/*
!uploads/.gitkeep

# --- Scripts & Tools ---
# Ignore temporary outputs from scripts
scripts/output/

# --- Documentation ---
*.md
!README.md
!docs/
!docs/**/*.md
